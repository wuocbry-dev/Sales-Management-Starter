{
  "module": "integrations",
  "basePath": "/api/integrations",
  "variables": {
    "baseUrl": "{{baseUrl}}",
    "accessToken": "{{accessToken}}"
  },
  "endpoints": [
    {
      "module": "integration.ecommerce",
      "method": "GET",
      "path": "/api/integrations/channels",
      "authRequired": true,
      "bodyType": "none",
      "requestDto": null
    },
    {
      "module": "integration.ecommerce",
      "method": "POST",
      "path": "/api/integrations/channels",
      "authRequired": true,
      "bodyType": "raw",
      "requestDto": "com.yourcompany.salesmanagement.module.integration.ecommerce.dto.request.CreateIntegrationChannelRequest"
    },
    {
      "module": "integration.ecommerce",
      "method": "GET",
      "path": "/api/integrations/product-mappings",
      "authRequired": true,
      "bodyType": "none",
      "requestDto": null
    },
    {
      "module": "integration.ecommerce",
      "method": "POST",
      "path": "/api/integrations/product-mappings",
      "authRequired": true,
      "bodyType": "raw",
      "requestDto": "com.yourcompany.salesmanagement.module.integration.ecommerce.dto.request.CreateIntegrationProductMappingRequest"
    }
  ]
}

